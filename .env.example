# Copiar a .env (no subir .env al repositorio)
# Atlas: en MongoDB Atlas → Connect → Drivers → copiar la URI (reemplazar <password>).
# Network Access: agregar tu IP (o 0.0.0.0/0 solo para pruebas).
# Prueba local sin Atlas: MONGODB_URI=mongodb://127.0.0.1:27017

MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=proyecto2
MONGODB_DATABASE=encuesta_proyecto2
SERVER_PORT=7000
# JWT: mínimo 32 caracteres; en producción use un secreto aleatorio largo
JWT_SECRET=defina-un-secreto-de-al-menos-32-caracteres
JWT_EXPIRES_HOURS=24
